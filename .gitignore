venv/
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints

# VS Code settings
.vscode/

# Streamlit settings - don't ignore
# .streamlit/

# Streamlit secrets (set these in Streamlit Cloud UI)
.streamlit/secrets.toml

# User uploaded files
uploads/*
!uploads/.gitkeep

# TensorFlow logs - except those handled by Git LFS
events.out.tfevents.*
# Don't ignore .h5 model files (handled by Git LFS)
!*.h5

# Environment variables
.env

# Backup files
*.bak

# Keep empty directories

# Don't ignore __init__.py files
!**/__init__.py

# Ensure bytecode stays ignored even with later negation rules
models/**/__pycache__/
utils/**/__pycache__/
models/**/*.py[cod]
utils/**/*.py[cod]

# Training logs
saved_models/*.log
